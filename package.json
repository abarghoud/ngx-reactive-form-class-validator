{
  "name": "ngx-reactive-form-class-validator",
  "description": "A lightweight library for dynamically validate Angular reactive forms using class-validator library.",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": [
    "ng",
    "angular",
    "library",
    "ngx",
    "typescript",
    "reactive-forms",
    "class-validator",
    "dynamic-validator",
    "validation",
    "validator"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abarghoud/ngx-reactive-form-class-validator.git"
  },
  "bugs": {
    "url": "https://github.com/abarghoud/ngx-reactive-form-class-validator/issues"
  },
  "scripts": {
    "ng": "nx",
    "nx": "nx",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test ngx-reactive-form-class-validator",
    "lint": "nx run-many -t lint",
    "e2e": "ng e2e",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "affected:build": "nx affected:build",
    "affected:e2e": "nx affected:e2e",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "affected:dep-graph": "nx affected:dep-graph",
    "affected": "nx affected",
    "format": "nx format:write",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "update": "ng update @nx/workspace",
    "workspace-schematic": "nx workspace-schematic",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "test:lib:coverage": "nx test ngx-reactive-form-class-validator --coverage",
    "build:lib": "nx build ngx-reactive-form-class-validator",
    "build:lib-pack": "npm run build:lib && npm run copy-files && cd dist/libs/ngx-reactive-form-class-validator && npm pack",
    "copy-readme": "cp ./README.md ./dist/libs/ngx-reactive-form-class-validator",
    "copy-license": "cp ./LICENSE.txt ./dist/libs/ngx-reactive-form-class-validator",
    "copy-changelog": "cp ./Changelog.md ./dist/libs/ngx-reactive-form-class-validator",
    "copy-files": "run-s copy-readme copy-license",
    "bump-version:major": "cd libs/ngx-reactive-form-class-validator && npm version major --force",
    "bump-version:minor": "cd libs/ngx-reactive-form-class-validator && npm version minor --force",
    "bump-version:patch": "cd libs/ngx-reactive-form-class-validator && npm version patch --force",
    "pre-publish:minor": "run-s bump-version:minor build:lib-pack",
    "pre-publish:major": "run-s bump-version:major build:lib-pack",
    "pre-publish:patch": "run-s bump-version:patch build:lib-pack"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.1.3",
    "@angular/common": "21.1.3",
    "@angular/compiler": "21.1.3",
    "@angular/core": "21.1.3",
    "@angular/forms": "21.1.3",
    "@angular/platform-browser": "21.1.3",
    "@angular/platform-browser-dynamic": "21.1.3",
    "@angular/router": "21.1.3",
    "@nx/angular": "22.4.5",
    "cerialize": "^0.1.18",
    "class-validator": "^0.14.3",
    "rxjs": "7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "21.1.3",
    "@angular-devkit/schematics": "21.1.3",
    "@angular/build": "21.1.3",
    "@angular/cli": "21.1.3",
    "@angular/compiler-cli": "21.1.3",
    "@angular/language-service": "21.1.3",
    "@nx/cypress": "22.4.5",
    "@nx/eslint-plugin": "22.4.5",
    "@nx/jest": "22.4.5",
    "@nx/js": "22.4.5",
    "@nx/workspace": "22.4.5",
    "@schematics/angular": "21.1.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.11",
    "@swc/helpers": "0.5.18",
    "@types/jest": "30.0.0",
    "@types/node": "25.1.0",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "cypress": "^15.9.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-cypress": "5.2.1",
    "jest": "30.0.5",
    "jest-environment-jsdom": "30.0.5",
    "jest-preset-angular": "16.0.0",
    "jest-util": "30.0.5",
    "ng-packagr": "21.1.0",
    "npm-run-all": "^4.1.5",
    "nx": "22.4.5",
    "postcss": "^8.5.6",
    "postcss-import": "16.1.1",
    "postcss-preset-env": "11.1.2",
    "postcss-url": "10.1.3",
    "prettier": "3.8.1",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  }
}
